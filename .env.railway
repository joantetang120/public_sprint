# Railway Production Environment Variables
# Copy these to Railway Dashboard → Your Service → Variables

# ============================================
# CRITICAL: Application Settings
# ============================================
APP_NAME=PublicSprint
APP_ENV=production
APP_KEY=base64:vX2xPZWGs/qsUBi+N6tJO2+S9Lgx+ybCFulEcj9ESxM=
APP_DEBUG=false
APP_URL=${{RAILWAY_PUBLIC_DOMAIN}}

# ============================================
# OPTION 1: PostgreSQL (Recommended)
# ============================================
# After adding PostgreSQL database in Railway:
# 1. Go to Variables tab
# 2. Click "Add Reference" → Select PostgreSQL
# 3. These variables will auto-populate:

DB_CONNECTION=pgsql
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_DATABASE=${{Postgres.PGDATABASE}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# ============================================
# OPTION 2: MySQL (Alternative)
# ============================================
# If you prefer MySQL, add MySQL database instead:
# Then use these variables:

# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ============================================
# Session, Cache, Queue
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ============================================
# Filesystem (Cloudinary for uploads)
# ============================================
FILESYSTEM_DISK=cloudinary
CLOUDINARY_CLOUD_NAME=dlxzjeqbz
CLOUDINARY_API_KEY=144532644859176
CLOUDINARY_API_SECRET=6bFPPMSWxjNH8S_bwx5x1UpO0_o
CLOUDINARY_URL=cloudinary://144532644859176:6bFPPMSWxjNH8S_bwx5x1UpO0_o@dlxzjeqbz

# ============================================
# Pusher (Real-time features)
# ============================================
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=2075747
PUSHER_APP_KEY=4027594ef6415333e661
PUSHER_APP_SECRET=46b37af0f9e65470c6ee
PUSHER_APP_CLUSTER=mt1

# ============================================
# Vite (Frontend)
# ============================================
VITE_PUSHER_APP_KEY=4027594ef6415333e661
VITE_PUSHER_APP_CLUSTER=mt1

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
